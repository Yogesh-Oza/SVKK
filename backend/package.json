{
  "name": "svkk-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "install:build": "npm install && npm run build",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy && prisma generate",
    "db:setup": "prisma db push && prisma db seed && tsx scripts/seed-data-md.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:data-md": "tsx scripts/seed-data-md.ts",
    "db:transfer-local": "tsx scripts/transfer-local-to-remote.ts",
    "user:create": "tsx scripts/create-user.ts",
    "legacy-migrate": "tsx scripts/legacy-migrate/run.ts",
    "legacy-migrate:rollback": "tsx scripts/legacy-migrate/rollback-run.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "googleapis": "^159.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pino": "^9.14.0",
    "pino-http": "^11.0.0",
    "zod": "^3.24.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^6.19.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
