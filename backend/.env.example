NODE_ENV=development
PORT=4000
DATABASE_URL="mysql://root:root@localhost:3306/svkk"
# Legacy DB: import techuico_insurance.sql into MySQL, then use one of:
# DATABASE_URL_LEGACY="mysql://root:root@localhost:3306/techuico_insurance"
# LEGACY_DATABASE=techuico_insurance
ACCESS_TOKEN_SECRET="replace-with-32-char-min-secret-key-here!!"
REFRESH_TOKEN_SECRET="replace-with-another-32-char-secret-key!"
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
# Comma-separated for alternate dev ports (e.g. when 3000 is in use)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# When the web app and API are on different hosts (e.g. Vercel + Render), use none + exact HTTPS origin in CORS:
# COOKIE_SAME_SITE=none
# CORS_ORIGIN=https://your-app.vercel.app
COOKIE_SAME_SITE=lax
CSV_DUPLICATE_MODE=block
UPLOAD_DIR=./uploads

# SVKK app base URL — used when building new notification links and email app links.
# Set this to your production web URL on the server (e.g. https://mediclaim.yourdomain.com).
# Holder emails use the Policy URL field on each policy (OneDrive/document link), not this URL.
FRONTEND_APP_URL=http://localhost:3000

# SMTP (optional — in-app notifications work without email)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=SVKK <noreply@svkk.local>

# Google Drive (optional): policy document upload via POST /api/v1/upload/google-drive
# 1. Create a service account, download JSON key.
# 2. Create or pick a Drive folder; share it with the service account email as Editor.
# 3. Set folder ID and credentials (either path or inline JSON):
# GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-sa.json
# If the key file lives in backend/: GOOGLE_APPLICATION_CREDENTIALS=./google-cloud-vision.json
# Or: GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# OneDrive / SharePoint (recommended): policy document upload via POST /api/v1/upload/one-drive
# 1. Register an app in Azure Entra ID.
# 2. Add Microsoft Graph Application permission: Files.ReadWrite.All and grant admin consent.
# 3. Create client secret, and collect tenant/client IDs.
# 4. Get drive ID (target OneDrive/SharePoint library) and optional folder path.
# 5. Ensure org sharing policy allows "Anyone with the link" if you need public read-only links.
# MS_TENANT_ID=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_DRIVE_ID=
# MS_DRIVE_FOLDER_PATH=SVKK/Policies

