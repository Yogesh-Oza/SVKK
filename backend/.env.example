NODE_ENV=development
PORT=4000
DATABASE_URL="mysql://root:root@localhost:3306/svkk"
# Legacy DB: import techuico_insurance.sql into MySQL, then use one of:
# DATABASE_URL_LEGACY="mysql://root:root@localhost:3306/techuico_insurance"
# LEGACY_DATABASE=techuico_insurance
ACCESS_TOKEN_SECRET="replace-with-32-char-min-secret-key-here!!"
REFRESH_TOKEN_SECRET="replace-with-another-32-char-secret-key!"
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
# Comma-separated for alternate dev ports (e.g. when 3000 is in use)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# When the web app and API are on different hosts (e.g. Vercel + Render), use none + exact HTTPS origin in CORS:
# COOKIE_SAME_SITE=none
# CORS_ORIGIN=https://your-app.vercel.app
COOKIE_SAME_SITE=lax
CSV_DUPLICATE_MODE=block
UPLOAD_DIR=./uploads
