# SVKK — nginx for https://svkk.techui.co.in
#
# DNS: svkk.techui.co.in → A record → 159.89.161.19
#
# Setup:
#   sudo apt install -y nginx certbot python3-certbot-nginx
#   sudo cp deploy/nginx-svkk-https.conf.example /etc/nginx/sites-available/svkk
#   sudo ln -sf /etc/nginx/sites-available/svkk /etc/nginx/sites-enabled/svkk
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d svkk.techui.co.in
#
# Then update:
#   GitHub secret NEXT_PUBLIC_API_URL=https://svkk.techui.co.in/api/v1
#   /var/www/svkk-backend/.env  CORS_ORIGIN=https://svkk.techui.co.in
#   /var/www/svkk-backend/.env  FRONTEND_APP_URL=https://svkk.techui.co.in
# Redeploy frontend +: pm2 restart svkk-api
#
# Service workers require a trusted cert (Let's Encrypt). Self-signed IP certs block SW.

server {
    listen 80;
    server_name svkk.techui.co.in;

    # Frontend (Next.js on 3002)
    location / {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Backend API (Express on 4000)
    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# After `certbot --nginx`, Certbot adds a second server { listen 443 ssl; ... } block
# with certificates under /etc/letsencrypt/live/svkk.techui.co.in/
