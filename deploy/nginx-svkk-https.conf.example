# SVKK — HTTPS reverse proxy (required for offline page caching / service worker)
#
# Browsers only register service workers on secure origins:
#   https://your-domain  OR  https://159.89.161.19  OR  http://localhost
# Plain http://159.89.161.19:3002 cannot cache pages for offline reload.
#
# Setup (Ubuntu + nginx):
#   sudo apt install nginx
#   sudo mkdir -p /etc/nginx/ssl
#   sudo openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout /etc/nginx/ssl/svkk.key \
#     -out /etc/nginx/ssl/svkk.crt \
#     -subj "/CN=159.89.161.19"
#   sudo cp deploy/nginx-svkk-https.conf.example /etc/nginx/sites-available/svkk
#   sudo ln -sf /etc/nginx/sites-available/svkk /etc/nginx/sites-enabled/svkk
#   sudo nginx -t && sudo systemctl reload nginx
#
# Then update:
#   GitHub secret NEXT_PUBLIC_API_URL=https://159.89.161.19/api/v1
#   /var/www/svkk-backend/.env  CORS_ORIGIN=https://159.89.161.19
#   /var/www/svkk-backend/.env  FRONTEND_APP_URL=https://159.89.161.19
# Redeploy frontend + restart backend.
#
# First visit: open https://159.89.161.19 → accept certificate warning → login →
# Policies → Download all policies. After that, /policies works offline on reload.

server {
    listen 443 ssl;
    server_name 159.89.161.19;

    ssl_certificate     /etc/nginx/ssl/svkk.crt;
    ssl_certificate_key /etc/nginx/ssl/svkk.key;

    # Frontend (Next.js on 3002)
    location / {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Backend API (Express on 4000)
    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# Optional: redirect HTTP → HTTPS
server {
    listen 80;
    server_name 159.89.161.19;
    return 301 https://$host$request_uri;
}
